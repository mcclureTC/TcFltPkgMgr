# Local configuration — site-specific, may contain credentials
config/feeds.local.json
config/settings.local.json
config/profiles.json

# Credential stores — never commit these
config/credentials.win.json
config/credentials.local.enc
config/credentials.key
config/target-meta.local.json

# Target store — machine-specific fleet configuration
config/targets.local.json

# Command logs — operational data, not source code
logs/

# Catch-all for any future .local files
*.local.json

# Local exports — fleet target CSVs are machine-specific operational data
*.csv

# PowerShell temp files
*.tmp

# Debug logs — never commit
debug.log

# Test run history — machine-specific
config/test-results.json

# Ansible working files — generated at runtime, contain host-specific data
ansible/inventory/
ansible/playbooks/
ansible/logs/
ansible/*.retry

# Docker build cache (not source files)
docker/.build-cache/